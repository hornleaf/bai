{"name": "get_display_brightness", "depend": "powershell.exe:WindowsPowerShell", "description": "获取显示器亮度", "function": "powershell.exe -c 'Get-Ciminstance -Namespace root/WMI -ClassName WmiMonitorBrightness | Select -ExpandProperty \"CurrentBrightness\"'"}
{"name": "set_display_brightness", "depend": "powershell.exe:WindowsPowerShell", "description": "设置显示器亮度，需要先获取亮度", "function": "powershell.exe -c \"(Get-WmiObject -Namespace root/WMI -Class WmiMonitorBrightnessMethods).WmiSetBrightness(1,$1)\"", "parameters": {"type": "object", "properties": {"brightness": {"type": "string", "description": "亮度值 (0-100)", "minimum": 1, "maximum": 100}},"required": ["brightness"]}}
