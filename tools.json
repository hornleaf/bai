{"name": "get_wiki", "depend": "baidu-wiki:baidubaike-shell", "description": "百度百科搜索", "function": "baidu-wiki \"$1\" \"$2\"", "parameters": {"type": "object", "properties": {"query": {"type": "string", "description": "要搜索的关键词"}, "option": {"type": "string","description": "输出格式", "enum": ["--json", "--text"]}}, "required": ["query","option"]}}
{"name": "get_date", "description": "获取当前日期", "function": "date"}
{"name": "get_system_info", "depend": "fastfetch", "description": "获取系统信息", "function": "fastfetch -l none"}
{"name": "run_command", "explicitly": "true", "description": "运行 Shell 命令", "function": "[[ \"$@\" == {} ]] && { echo 'ERROR 工具参数为空';return;};eval \"$@\"", "parameters": {"type": "object", "properties": {"command": {"type": "string", "description": "要执行的 Shell 命令"}}, "required": ["command"]}}
{"name": "get_hitokoto", "description": "获取一言","function": "local ORIGIN_HITOKOTO=\"$(curl -Ls --connect-timeout 1 --max-time 1 \"https://v1.hitokoto.cn\" | sed -E 's|^\\{||;s|\\}$|\\n|;s|,\"|,\\n\"|g')\";local HITOKOTO_ONE=\"$(grep -oP '(?<=\"hitokoto\":\").*?(?=\",)' <<<\"$ORIGIN_HITOKOTO\")\";local HITOKOTO_FROM=\"$(grep -oP '(?<=\"from\":\").*?(?=\",)' <<<\"$ORIGIN_HITOKOTO\")\";local HITOKOTO_AUTHOR=\"$(grep -oP '(?<=\"from_who\":\").*?(?=\",)' <<<\"$ORIGIN_HITOKOTO\")\";printf '%s —— %s\\n' \"${HITOKOTO_ONE}\" \"『${HITOKOTO_FROM}』${HITOKOTO_AUTHOR}\""}
{"name": "get_weather", "description": "获取当地天气", "function": "curl -s https://zh.wttr.in/\"$(curl -s https://ip9.com.cn/get | jq -r '.data | .prov + \"省\" + .city + \"市\"')\""}
